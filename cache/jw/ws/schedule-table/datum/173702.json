 在地球科学数据处理中的关键作用，掌握从原始数据到可视化成果的完整流程，让复杂抽象的科学数据变得直观、生动、可解释。\n\n本课程对本科毕业论文、科研训练、以及未来研究生阶段的科研工作均具有重要支撑作用，是提升数据分析能力和科研竞争力的重要工具课程。", "scheduleRemark": null, "adminclasses": [{"id": 27052, "nameZh": "23大气科学", "nameEn": "23 Atmospheric Science", "code": "2307102", "grade": "2023", "stdCount": 9, "planCount": 0, "enabled": true, "abbrZh": "23大气", "abbrEn": "2307102"}, {"id": 27180, "nameZh": "23行星科学", "nameEn": "23 Planetary Science", "code": "2307202", "grade": "2023", "stdCount": 6, "planCount": 0, "enabled": true, "abbrZh": "23行星", "abbrEn": "2307202"}, {"id": 27021, "nameZh": "23地球物理学*", "nameEn": "23 Geophysics*", "code": "2307101*", "grade": "2023", "stdCount": 20, "planCount": 0, "enabled": true, "abbrZh": "23地物理*", "abbrEn": "2307101*"}], "scheduleJsonParams": [], "selectedStdCount": 0}], "scheduleList": [{"lessonId": 173702, "scheduleGroupId": 188853, "periods": 3.0, "date": "2026-03-03", "room": {"id": 244, "nameZh": "2301", "nameEn": "2301", "code": "2301", "building": {"id": 5, "nameZh": "第二教学楼", "nameEn": "NO.2", "code": "2", "campus": {"id": 9, "nameZh": "东区", "nameEn": "east campus", "code": "1"}}, "roomType": {"id": 47, "nameZh": "智慧型研讨室", "nameEn": "Smart Classroom", "code": "9"}, "floor": 3, "virtual": false, "seatsForLesson": 20, "remark": "电子屏，智慧教室", "seats": 0}, "weekday": 2, "startTime": 1555, "endTime": 1820, "teacherId": 963, "personId": 5910, "personName": "周任君", "experiment": null, "customPlace": null, "lessonType": null, "weekIndex": 1, "exerciseClass": null, "startUnit": 0, "endUnit": 0}, {"lessonId": 173702, "scheduleGroupId": 188853, "periods": 3.0, "date": "2026-03-10", "room": {"id": 244, "nameZh": "2301", "nameEn": "2301", "code": "2301", "building": {"id": 5, "nameZh": "第二教学楼", "nameEn": "NO.2", "code": "2", "campus": {"id": 9, "nameZh": "东区", "nameEn": "east campus", "code": "1"}}, "roomType": {"id": 47, "nameZh": "智慧型研讨室", "nameEn": "Smart Classroom", "code": "9"}, "floor": 3, "virtual": false, "seatsForLesson": 20, "remark": "电子屏，智慧教室", 